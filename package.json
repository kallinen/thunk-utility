{
    "name": "@kallinen/thunk-utility",
    "version": "0.3.5",
    "description": "TypeScript library for creating typed thunks.",
    "files": [
        "lib/**/*"
    ],
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "scripts": {
        "build": "tsc",
        "test": "cross-env NODE_ENV=test jest --detectOpenHandles --config ./jest.config.js --colors --verbose --forceExit",
        "format": "prettier --write \"src/**/*.ts\"",
        "lint": "tslint -p tsconfig.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kallinen/thunk-utility.git"
    },
    "author": "Kallinen Solutions Oy",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/kallinen/thunk-utility/issues"
    },
    "homepage": "https://github.com/kallinen/thunk-utility#readme",
    "peerDependencies": {
        "@reduxjs/toolkit": ">=2.0.0 <3.0.0"
    },
    "devDependencies": {
        "@types/jest": "^29.4.4",
        "cross-env": "^7.0.3",
        "jest": "^29.0.3",
        "prettier": "^2.7.1",
        "ts-jest": "^29.0.5",
        "tslint": "^6.1.3",
        "tslint-config-prettier": "^1.18.0",
        "typescript": "^5.9.3"
    },
    "directories": {
        "lib": "lib"
    }
}
